Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Theta]2", "[", 
   RowBox[{"d_", ",", "a_", ",", "u_"}], "]"}], ":=", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"ArcTan", "[", 
        RowBox[{
         RowBox[{"Sqrt", "[", "3", "]"}], "*", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{
              RowBox[{"a", "^", "2"}], "/", 
              RowBox[{"u", "^", "2"}]}]}], ")"}], "^", 
           RowBox[{"(", 
            RowBox[{"3", "/", "2"}], ")"}]}], "/", 
          RowBox[{"(", 
           RowBox[{"3", "*", 
            RowBox[{"(", 
             RowBox[{"d", "/", "u"}], ")"}], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", "*", 
               RowBox[{
                RowBox[{"a", "^", "2"}], "/", 
                RowBox[{"u", "^", "2"}]}]}], "-", "1"}], ")"}]}], ")"}]}]}], 
        "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "^", "2"}], "/", 
         RowBox[{"u", "^", "2"}]}], ">", "1"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"ArcTan", "[", 
          RowBox[{
           RowBox[{"Sqrt", "[", "3", "]"}], "*", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "+", 
               RowBox[{
                RowBox[{"a", "^", "2"}], "/", 
                RowBox[{"u", "^", "2"}]}]}], ")"}], "^", 
             RowBox[{"(", 
              RowBox[{"3", "/", "2"}], ")"}]}], "/", 
            RowBox[{"(", 
             RowBox[{"3", "*", 
              RowBox[{"(", 
               RowBox[{"d", "/", "u"}], ")"}], "*", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", "*", 
                 RowBox[{
                  RowBox[{"a", "^", "2"}], "/", 
                  RowBox[{"u", "^", "2"}]}]}], "-", "1"}], ")"}]}], ")"}]}]}],
           "]"}], "+", "Pi"}], ")"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "^", "2"}], "/", 
         RowBox[{"u", "^", "2"}]}], "<", "1"}]}], "}"}]}], "}"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Theta]2approx", "[", 
   RowBox[{"d_", ",", "a_", ",", "u_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Pi", "/", "2"}], "-", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Sqrt", "[", "3", "]"}], "*", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{
            RowBox[{"a", "^", "2"}], "/", 
            RowBox[{"u", "^", "2"}]}]}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"3", "/", "2"}], ")"}]}], "/", 
        RowBox[{"(", 
         RowBox[{"3", "*", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "*", 
             RowBox[{
              RowBox[{"a", "^", "2"}], "/", 
              RowBox[{"u", "^", "2"}]}]}], "-", "1"}], ")"}]}], ")"}]}]}], 
      ")"}], "^", 
     RowBox[{"(", 
      RowBox[{"-", "1"}], ")"}]}], "*", 
    RowBox[{"(", 
     RowBox[{"d", "/", "u"}], ")"}]}]}]}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.982760177189981*^9, 3.982760306285878*^9}, {
